{
  "name": "pdfxtn",
  "version": "1.2.2",
  "description": "PDF Mana — a Chrome extension to Merge, Arrange, Nip & Adjust PDF pages locally.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project=functional --project=a11y",
    "visual": "playwright test --project=visual",
    "visual:update": "playwright test --project=visual --update-snapshots",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "node scripts/release.mjs",
    "release:publish": "node scripts/release.mjs --publish",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/nunito": "^5.2.7",
    "fflate": "^0.8.3",
    "lucide-react": "^1.21.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@crxjs/vite-plugin": "^2.0.0-beta.34",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
